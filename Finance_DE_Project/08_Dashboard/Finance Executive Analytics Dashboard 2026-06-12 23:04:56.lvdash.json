{
  "datasets": [
    {
      "name": "monthly_revenue",
      "displayName": "Monthly Revenue Trend",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  workspace.default.dashboard_monthly_revenue\n",
        "ORDER BY\n",
        "  year,\n",
        "  month"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "country_revenue",
      "displayName": "Country Revenue Analysis",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  workspace.default.dashboard_country_revenue\n",
        "ORDER BY\n",
        "  country_total_amount DESC"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "executive_kpis",
      "displayName": "Executive KPIs",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  workspace.default.executive_kpis"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "transaction_type",
      "displayName": "Transaction Type Distribution",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  workspace.default.dashboard_transaction_type\n",
        "ORDER BY\n",
        "  total_amount DESC"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "fraud_by_type",
      "displayName": "Fraud by Transaction Type",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  workspace.default.dashboard_fraud_by_type\n",
        "ORDER BY\n",
        "  fraud_count DESC"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "top_customers",
      "displayName": "Top 10 Customers",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  workspace.default.dashboard_top_customers\n",
        "ORDER BY\n",
        "  total_spending DESC\n",
        "LIMIT 10"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "fraud_summary",
      "displayName": "Fraud Risk Distribution",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  workspace.default.dashboard_fraud_summary\n",
        "ORDER BY\n",
        "  count DESC"
      ],
      "catalog": "workspace",
      "schema": "default"
    }
  ],
